# Copy this file to ".env.local" and fill in real values.
# .env.local is already blocked by .gitignore, so it never goes to GitHub.

# --- Supabase (safe to use in the frontend) ---
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- SECRET: server-side only (Supabase Edge Function / Vercel env) ---
# Do NOT add a VITE_ prefix to these and do NOT use them in frontend code.
ANTHROPIC_API_KEY=your-anthropic-key
STRIPE_SECRET_KEY=your-stripe-secret-key
